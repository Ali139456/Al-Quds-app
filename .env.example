# Backend API URL. Used for syncing users, orders, and menu to the admin dashboard.
# - Same machine / web: http://localhost:4000
# - App on phone: use your computer's IP so the phone can reach the backend, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.5:4000
#   (Find your IP: Mac = System Settings > Network > Wi-Fi > Details)
# Copy this file to .env and set the value. Restart Expo (npm start) after changing.
EXPO_PUBLIC_API_URL=http://localhost:4000

# Google Maps Geocoding API key (for address lookup & "Use current location")
# Enable "Geocoding API" in Google Cloud Console: https://console.cloud.google.com/
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
